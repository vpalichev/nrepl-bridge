{:deps         true
 :nrepl        {:port 0}
 :source-paths ["src/clj" "src/cljs" "src/cljc"]
 :builds {:app {:target    :browser
                :output-dir "resources/public/js"
                :asset-path "/js"
                :modules   {:main {:init-fn app.core/init}}
                :devtools  {:after-load app.core/after-load}}}}
